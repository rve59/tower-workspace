# TOWER Ecosystem: Standard Ignore Rules
# Updated: 2026-04-23

# --- OS Specific ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- VS Code Managed Project ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# --- Python Project (uv / venv / pip) ---
__pycache__/
*.py[cod]
*$py.class
.python-version

# Virtual Environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Distribution / Packaging
dist/
build/
*.egg-info/
*.egg
.installed.cfg
.pip-wheel-metadata/

# Testing & Coverage
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.hypothesis/
.ruff_cache/

# Type Checking
.mypy_cache/
.pyre/
.pytype/

# Jupyter Notebooks
.ipynb_checkpoints

# --- Node.js / Frontend Project ---
node_modules/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build Outputs
.next/
out/
.docusaurus/
.cache/
.parcel-cache/
.turbo/

